#!/usr/bin/env bash
set -e  # Exit on error

# Define the folders to stow, comma-separated
STOW_FOLDERS=${STOW_FOLDERS:-"alacritty,hypr,i3,nvim,tmux,waybar,zsh"}

# Convert to array using comma as separator
IFS=',' read -r -a folders <<< "$STOW_FOLDERS"

echo ""
echo "🔧 Starting dotfile stow process..."
echo ""

for folder in "${folders[@]}"; do
    if [[ -d "$folder" ]]; then
        echo "✅ Stowing: $folder"
        stow -D "$folder"
        stow "$folder"
    else
        echo "❌ Skipping: $folder (not found in $(pwd))"
    fi
done

echo ""
echo "[Info] Done"

